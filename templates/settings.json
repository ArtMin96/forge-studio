{
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "75"
  },
  "permissions": {
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git push * --force)",
      "Bash(git push * -f)",
      "Bash(git reset --hard *)",
      "Bash(git checkout -- *)",
      "Bash(git checkout . *)",
      "Bash(git clean -f *)",
      "Bash(git clean -fd *)",
      "Bash(git branch -D *)",
      "Bash(* DROP TABLE *)",
      "Bash(* DROP DATABASE *)",
      "Bash(* TRUNCATE *)",
      "Bash(curl * | bash *)",
      "Bash(curl * | sh *)",
      "Bash(wget * | bash *)",
      "Bash(wget * | sh *)"
    ]
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high"
}
